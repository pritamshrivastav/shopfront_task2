<%- include('partials/header', { title: product.name }) %>

<div class="breadcrumb">
  <a href="/">Catalog</a> &rsaquo; <a href="/?category=<%= encodeURIComponent(product.category) %>"><%= product.category %></a> &rsaquo; <%= product.name %>
</div>

<div class="product-detail">
  <div class="image-frame">
    <img src="<%= product.image %>" alt="<%= product.name %>" />
  </div>

  <div class="meta">
    <div class="category-label"><%= product.category %> · № <%= String(product.id).padStart(3, '0') %></div>
    <h1><%= product.name %></h1>
    <span class="price">$<%= product.price.toFixed(2) %></span>

    <p class="description"><%= product.description %></p>

    <% if (product.stock === 0) { %>
      <p class="stock-note low" style="margin-bottom: 18px; display:block;">Currently out of stock</p>
      <button class="btn btn-primary btn-full" disabled>Out of Stock</button>
    <% } else { %>
      <form action="/cart/add" method="POST">
        <input type="hidden" name="productId" value="<%= product.id %>" />
        <div class="qty-row">
          <label for="quantity">Quantity</label>
          <input type="number" id="quantity" name="quantity" value="1" min="1" max="<%= product.stock %>" />
          <span class="stock-note"><%= product.stock %> available</span>
        </div>
        <button type="submit" class="btn btn-primary btn-full">Add to Cart</button>
      </form>
    <% } %>
  </div>
</div>

<% if (related.length > 0) { %>
  <section class="related-section">
    <h2>More from <%= product.category %></h2>
    <div class="product-grid">
      <% related.forEach(p => { %>
        <div class="product-card">
          <span class="catalog-number">№ <%= String(p.id).padStart(3, '0') %></span>
          <a href="/products/<%= p.id %>">
            <img class="thumb" src="<%= p.image %>" alt="<%= p.name %>" loading="lazy" />
          </a>
          <div class="card-body">
            <div class="category-label"><%= p.category %></div>
            <h3><a href="/products/<%= p.id %>"><%= p.name %></a></h3>
            <p class="desc-snip"><%= p.description %></p>
            <div class="price-row">
              <span class="price">$<%= p.price.toFixed(2) %></span>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </section>
<% } %>

<%- include('partials/footer') %>
