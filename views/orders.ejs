<%- include('partials/header', { title: 'My Orders' }) %>

<h1 style="margin-bottom: 24px;">My Orders</h1>

<% if (orders.length === 0) { %>
  <div class="empty-state">
    <h2>No orders yet</h2>
    <p>When you place an order, it'll show up here.</p>
    <a href="/" class="btn btn-primary">Browse the catalog</a>
  </div>
<% } else { %>
  <% orders.forEach(order => { %>
    <a href="/orders/<%= order.id %>" style="display:block;">
      <div class="order-card">
        <div class="order-card-top">
          <span class="order-num">Order #<%= String(order.id).padStart(5, '0') %></span>
          <span class="status-badge"><%= order.status %></span>
          <span class="order-date"><%= new Date(order.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
        </div>
        <div class="stock-note"><%= order.items.length %> item<%= order.items.length !== 1 ? 's' : '' %> · Total $<%= order.total.toFixed(2) %></div>
      </div>
    </a>
  <% }) %>
<% } %>

<%- include('partials/footer') %>
